{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scene-exchange-contracts.local/v1/shared_exchange_protocol/reconstruction_result.schema.json",
  "title": "Reconstruction Build Result",
  "description": "NeuralSceneBridge's terminal or partial product inventory for one reconstruction request.",
  "allOf": [
    {
      "$ref": "shared_envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["schema_version", "message_type", "producer", "payload"],
      "properties": {
        "schema_version": {
          "const": "reconstruction_result.v1"
        },
        "message_type": {
          "const": "reconstruction.build.result"
        },
        "producer": {
          "allOf": [
            {
              "$ref": "shared_envelope.schema.json#/$defs/producer"
            },
            {
              "properties": {
                "project": {
                  "const": "NeuralSceneBridge"
                }
              }
            }
          ]
        },
        "payload": {
          "type": "object",
          "required": [
            "job_id",
            "scene_id",
            "status",
            "started_at",
            "finished_at",
            "artifacts",
            "product_status",
            "metrics"
          ],
          "properties": {
            "job_id": {
              "$ref": "shared_envelope.schema.json#/$defs/safe_id"
            },
            "scene_id": {
              "$ref": "shared_envelope.schema.json#/$defs/scene_token"
            },
            "scene_version": {
              "$ref": "shared_envelope.schema.json#/$defs/safe_id"
            },
            "status": {
              "enum": ["succeeded", "partial", "failed", "cancelled"]
            },
            "started_at": {
              "$ref": "shared_envelope.schema.json#/$defs/timestamp"
            },
            "finished_at": {
              "$ref": "shared_envelope.schema.json#/$defs/timestamp"
            },
            "artifacts": {
              "type": "array",
              "items": {
                "allOf": [
                  {
                    "$ref": "shared_artifact_ref.schema.json"
                  },
                  {
                    "properties": {
                      "role": {
                        "enum": [
                          "scenario_ir",
                          "ncore_manifest",
                          "ncore_store",
                          "nurec_usdz",
                          "nurec_checkpoint",
                          "nurec_config",
                          "reconstruction_package",
                          "build_log"
                        ]
                      }
                    }
                  }
                ]
              },
              "maxItems": 256
            },
            "product_status": {
              "type": "object",
              "properties": {
                "ncore_dataset": {
                  "$ref": "#/$defs/product_status"
                },
                "nurec_reconstruction": {
                  "$ref": "#/$defs/product_status"
                },
                "reconstruction_package": {
                  "$ref": "#/$defs/product_status"
                }
              },
              "additionalProperties": false
            },
            "metrics": {
              "type": "object",
              "required": ["duration_sec"],
              "properties": {
                "duration_sec": {
                  "type": "number",
                  "minimum": 0
                },
                "sample_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "camera_frame_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "backend": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                },
                "backend_version": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                }
              },
              "additionalProperties": false
            },
            "warnings": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 2048
              },
              "maxItems": 128
            },
            "error": {
              "$ref": "shared_envelope.schema.json#/$defs/error"
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "status": {
                    "enum": ["succeeded", "partial"]
                  }
                },
                "required": ["status"]
              },
              "then": {
                "properties": {
                  "artifacts": {
                    "minItems": 1
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "status": {
                    "enum": ["failed", "cancelled"]
                  }
                },
                "required": ["status"]
              },
              "then": {
                "required": ["error"]
              }
            }
          ],
          "additionalProperties": false
        }
      }
    }
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "product_status": {
      "enum": ["not_requested", "succeeded", "failed", "skipped"]
    }
  },
  "examples": [
    {
      "protocol_version": "shared_exchange_protocol.v1",
      "schema_version": "reconstruction_result.v1",
      "message_id": "msg-reconstruction-result-001",
      "message_type": "reconstruction.build.result",
      "created_at": "2026-07-13T12:20:00Z",
      "producer": {
        "project": "NeuralSceneBridge",
        "component": "nurec-build-worker",
        "version": "1.0.0"
      },
      "correlation": {
        "correlation_id": "flow-cc8c0bf57f984915a77078b10eb33198",
        "root_message_id": "msg-selection-001",
        "causation_message_id": "msg-reconstruction-request-001"
      },
      "idempotency": {
        "key": "reconstruction-result/nuscenes/cc8c0bf57f984915a77078b10eb33198/v001",
        "scope": "scene"
      },
      "payload": {
        "job_id": "reconstruction-cc8c0bf57f984915a77078b10eb33198-v001",
        "scene_id": "cc8c0bf57f984915a77078b10eb33198",
        "scene_version": "v001",
        "status": "succeeded",
        "started_at": "2026-07-13T12:00:05Z",
        "finished_at": "2026-07-13T12:20:00Z",
        "artifacts": [
          {
            "schema_version": "shared_artifact_ref.v1",
            "path": "scenes/cc8c0bf57f984915a77078b10eb33198/v001/reconstruction/last.usdz",
            "role": "nurec_usdz",
            "media_type": "model/vnd.usdz+zip",
            "sha256": "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd",
            "size_bytes": 1048576,
            "immutable": true
          },
          {
            "schema_version": "shared_artifact_ref.v1",
            "path": "scenes/cc8c0bf57f984915a77078b10eb33198/v001/reconstruction/reconstruction_package.json",
            "role": "reconstruction_package",
            "media_type": "application/json",
            "sha256": "eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee",
            "size_bytes": 2048,
            "immutable": true
          }
        ],
        "product_status": {
          "ncore_dataset": "succeeded",
          "nurec_reconstruction": "succeeded",
          "reconstruction_package": "succeeded"
        },
        "metrics": {
          "duration_sec": 1195.0,
          "sample_count": 39,
          "camera_frame_count": 234,
          "backend": "nurec"
        },
        "warnings": []
      }
    }
  ]
}

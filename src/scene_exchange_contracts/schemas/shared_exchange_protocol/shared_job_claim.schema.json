      "$ref": "shared_envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["schema_version", "message_type", "payload"],
      "properties": {
        "schema_version": {
          "const": "shared_job_claim.v1"
        },
        "message_type": {
          "const": "shared.job.claim"
        },
        "payload": {
          "type": "object",
          "required": [
            "job_id",
            "job_kind",
            "request_message_id",
            "worker_id",
            "lease_id",
            "attempt",
            "status",
            "claimed_at",
            "lease_expires_at"
          ],
          "properties": {
            "job_id": {
              "$ref": "shared_envelope.schema.json#/$defs/safe_id"
            },
            "job_kind": {
              "$ref": "shared_envelope.schema.json#/$defs/job_kind"
            },
            "request_message_id": {
              "$ref": "shared_envelope.schema.json#/$defs/safe_id"
            },
            "worker_id": {
              "$ref": "shared_envelope.schema.json#/$defs/safe_id"
            },
            "lease_id": {
              "$ref": "shared_envelope.schema.json#/$defs/safe_id"
            },
            "attempt": {
              "type": "integer",
              "minimum": 1
            },
            "status": {
              "const": "claimed"
            },
            "claimed_at": {
              "$ref": "shared_envelope.schema.json#/$defs/timestamp"
            },
            "lease_expires_at": {
              "$ref": "shared_envelope.schema.json#/$defs/timestamp"
            }
          },
          "additionalProperties": false
        }
      }
    }
  ],
  "unevaluatedProperties": false,
  "examples": [
